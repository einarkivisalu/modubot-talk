# train_weighted.py

import os
import json
import inspect
from dataclasses import dataclass
from typing import Dict, List, Any

import torch
import torch.nn.functional as F
from datasets import Dataset
from transformers import AutoTokenizer, AutoModelForCausalLM, TrainingArguments, Trainer
from peft import LoraConfig, PeftModel
from huggingface_hub import login


# ---------------- Config ----------------
model_id = "google/gemma-3-1b-it"
facts_path = "luuletused.json"          # your dataset
output_adapter_dir = "gemma_1.0_lora"
checkpoint_dir = "checkpoint_lora"
load_existing_adapter = True

# Token-level boost settings
keyword_boosts = {
    "fakt": 3.0,
    "teadmine": 2.0,
    "luuletus": 3.0,
    "luule": 3.0,
}

max_length = 512


# ---------------- HF login ----------------
hf_token = os.environ.get("HF_TOKEN") or os.environ.get("HUGGINGFACE_HUB_TOKEN")
if not hf_token:
    raise RuntimeError("Set HF_TOKEN in environment, e.g. export HF_TOKEN='hf_xxx'")
login(token=hf_token)


# ---------------- Tokenizer ----------------
tokenizer = AutoTokenizer.from_pretrained(model_id, trust_remote_code=True)

added_tokens = False
if tokenizer.pad_token_id is None:
    tokenizer.add_special_tokens({"pad_token": tokenizer.eos_token})
    added_tokens = True


# ---------------- Model ----------------
model = None
try:
    from transformers import Gemma3ForCausalLM  # type: ignore
    print("Loading model using Gemma3ForCausalLM.from_pretrained(...)")
    model = Gemma3ForCausalLM.from_pretrained(
        model_id,
        device_map="auto",
        trust_remote_code=True,
        ignore_mismatched_sizes=True,
        low_cpu_mem_usage=True,
    )
except Exception as e:
    print("Gemma3ForCausalLM not available or failed to load (falling back). Exception:", e)
    model = AutoModelForCausalLM.from_pretrained(
        model_id,
        device_map="auto",
        trust_remote_code=True,
        ignore_mismatched_sizes=True,
        low_cpu_mem_usage=True,
    )

if added_tokens:
    model.resize_token_embeddings(len(tokenizer))


# ---------------- LoRA config ----------------
lora_config = LoraConfig(
    r=8,
    lora_alpha=16,
    lora_dropout=0.05,
    bias="none",
    task_type="CAUSAL_LM",
    target_modules=[
        "q_proj", "k_proj", "v_proj", "o_proj",
        "gate_proj", "up_proj", "down_proj",
    ],
)


# ---------------- Load existing adapter as trainable ----------------
adapter_loaded = False
if load_existing_adapter and os.path.isdir(output_adapter_dir):
    try:
        print(f"Found existing adapter directory at {output_adapter_dir!r}, loading it...")
        model = PeftModel.from_pretrained(
            model,
            output_adapter_dir,
            device_map="auto",
            is_trainable=True,
        )
        adapter_loaded = True
        print("Successfully loaded existing LoRA adapter; continuing training.")
    except Exception as e:
        print("Warning: failed to load existing adapter; training will start fresh. Exception:", e)

model.config.use_cache = False


def print_trainable_params(m):
    trainable = 0
    total = 0
    for p in m.parameters():
        total += p.numel()
        if p.requires_grad:
            trainable += p.numel()
    print(f"Trainable params: {trainable} / {total}")


print_trainable_params(model)


# ---------------- Dataset ----------------
if not os.path.isfile(facts_path):
    raise RuntimeError(f"Training data not found at {facts_path!r}. Current working directory: {os.getcwd()}")

with open(facts_path, "r", encoding="utf-8") as f:
    examples = json.load(f)

if not isinstance(examples, list):
    raise RuntimeError(f"Expected a list of examples in {facts_path!r}.")

train_ds = Dataset.from_list(examples)


def format_example(ex):
    system_msg = "Sa oled abivalmis assistent. Vasta lühidalt ja eesti keeles."
    user_msg = ex.get("question", "").strip()
    assistant_msg = ex.get("answer", "").strip()

    if hasattr(tokenizer, "apply_chat_template"):
        try:
            messages = [
                {"role": "system", "content": system_msg},
                {"role": "user", "content": user_msg},
                {"role": "assistant", "content": assistant_msg},
            ]
            text = tokenizer.apply_chat_template(
                messages,
                tokenize=False,
                add_generation_prompt=False,
            )
            return {"text": text}
        except Exception:
            pass

    text = f"SYSTEM: {system_msg}\n\nUSER: {user_msg}\n\nASSISTANT: {assistant_msg}"
    return {"text": text}


train_ds = train_ds.map(format_example)

if "text" not in train_ds.column_names:
    raise RuntimeError("After mapping, train_ds does not contain a 'text' column.")


# ---------------- Helpers for token matching ----------------
def encode_variants(tokenizer, word: str) -> List[List[int]]:
    variants = [
        word,
        " " + word,
    ]
    out = []
    for v in variants:
        ids = tokenizer.encode(v, add_special_tokens=False)
        if ids and ids not in out:
            out.append(ids)
    return out


def find_all_subsequences(sequence: List[int], pattern: List[int]) -> List[int]:
    if len(pattern) == 0 or len(pattern) > len(sequence):
        return []
    hits = []
    for i in range(len(sequence) - len(pattern) + 1):
        if sequence[i : i + len(pattern)] == pattern:
            hits.append(i)
    return hits


keyword_patterns: Dict[str, List[List[int]]] = {
    kw: encode_variants(tokenizer, kw) for kw in keyword_boosts.keys()
}


# ---------------- Collator with token weights ----------------
@dataclass
class WeightedCollator:
    tokenizer: Any
    keyword_boosts: Dict[str, float]
    keyword_patterns: Dict[str, List[List[int]]]
    max_length: int = 512

    def __call__(self, features: List[Dict[str, Any]]) -> Dict[str, torch.Tensor]:
        texts = [f["text"] for f in features]

        batch = self.tokenizer(
            texts,
            padding=True,
            truncation=True,
            max_length=self.max_length,
            return_tensors="pt",
        )

        input_ids = batch["input_ids"]
        attention_mask = batch["attention_mask"]

        labels = input_ids.clone()
        labels[attention_mask == 0] = -100

        # Base weight = 1 for all real tokens
        loss_weights = torch.ones_like(input_ids, dtype=torch.float32)
        loss_weights[attention_mask == 0] = 0.0

        # Boost tokens that match important words
        for i in range(input_ids.size(0)):
            seq = input_ids[i].tolist()

            for kw, boost in self.keyword_boosts.items():
                for pat in self.keyword_patterns[kw]:
                    for start in find_all_subsequences(seq, pat):
                        end = start + len(pat)
                        # Boost all tokens in the matched span
                        for pos in range(start, end):
                            if labels[i, pos] != -100:
                                loss_weights[i, pos] = max(loss_weights[i, pos].item(), boost)

        batch["labels"] = labels
        batch["loss_weights"] = loss_weights
        return batch


collator = WeightedCollator(
    tokenizer=tokenizer,
    keyword_boosts=keyword_boosts,
    keyword_patterns=keyword_patterns,
    max_length=max_length,
)


# ---------------- Custom Trainer ----------------
class WeightedTrainer(Trainer):
    def compute_loss(self, model, inputs, return_outputs=False, num_items_in_batch=None):
        loss_weights = inputs.pop("loss_weights")
        labels = inputs.pop("labels")

        outputs = model(**inputs)
        logits = outputs.logits

        # Shift for causal LM
        shift_logits = logits[..., :-1, :].contiguous()
        shift_labels = labels[..., 1:].contiguous()
        shift_weights = loss_weights[..., 1:].contiguous()

        token_loss = F.cross_entropy(
            shift_logits.view(-1, shift_logits.size(-1)),
            shift_labels.view(-1),
            ignore_index=-100,
            reduction="none",
        ).view_as(shift_labels)

        active = (shift_labels != -100).float()
        weighted = token_loss * shift_weights * active
        denom = (shift_weights * active).sum().clamp_min(1.0)

        loss = weighted.sum() / denom
        return (loss, outputs) if return_outputs else loss


# ---------------- Training args ----------------
args = TrainingArguments(
    output_dir=checkpoint_dir,
    per_device_train_batch_size=2,
    gradient_accumulation_steps=2,
    learning_rate=2e-5,
    num_train_epochs=1,
    logging_steps=1,
    save_steps=50,
    bf16=(torch.cuda.is_available() and getattr(torch.cuda, "is_bf16_supported", lambda: False)()),
    report_to="none",
    remove_unused_columns=False,  # important for custom batch fields like loss_weights
)


# ---------------- Trainer setup ----------------
trainer_kwargs = {
    "model": model,
    "args": args,
    "train_dataset": train_ds,
    "data_collator": collator,
}

if not adapter_loaded:
    trainer_kwargs["peft_config"] = lora_config

sig = inspect.signature(WeightedTrainer.__init__)
accepted = set(sig.parameters.keys())
accepted.discard("self")
filtered_kwargs = {k: v for k, v in trainer_kwargs.items() if k in accepted}

print("Trainer supported parameters:", sorted(accepted))
print("Passing parameters:", sorted(filtered_kwargs.keys()))

trainer = WeightedTrainer(**filtered_kwargs)

# ---------------- Train ----------------
trainer.train()

# ---------------- Save ----------------
try:
    trainer.model.save_pretrained(output_adapter_dir)
except Exception:
    model.save_pretrained(output_adapter_dir)

tokenizer.save_pretrained(output_adapter_dir)

print(f"Done. Saved LoRA adapter and tokenizer to: {output_adapter_dir}")
